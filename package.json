{
  "name": "bid-or-bust",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bid or Bust MVP: a TypeScript bidding strategy prototype for weird salvage auctions.",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 18763 --strictPort",
