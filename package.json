    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "peerjs": "^1.5.5"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "typescript": "^5.8.3",
